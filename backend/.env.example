# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8080
MODE=mongo          # "mongo" | "fs"

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/tu_base_de_datos

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=24h

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.tu_api_key_aqui
SENDGRID_FROM=no-reply@tudominio.com

# ── Reseed automático (solo en producción/demo) ──────────────────────────────
ENABLE_DEMO_RESEED=false

# Secreto compartido para POST /api/system/reseed — lo llama el cron externo
# en .github/workflows/reseed-cron.yml (guardado ahí como Actions Secret,
# nunca en el repo). Generá algo random y largo, ej: openssl rand -hex 32
RESEED_SECRET=cambia_esto_por_un_secreto_largo_y_random

# ── Client (CORS) ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
