# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8080
MODE=mongo          # "mongo" | "fs"

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/ecommerce

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=24h

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM=no-reply@bookwise.com

# ── Client (CORS) ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
