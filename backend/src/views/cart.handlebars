<h2 style="margin-bottom:1.5rem">🛒 Carrito <code style="font-size:.8rem;background:#eee;padding:.1rem .4rem;border-radius:4px">{{cartId}}</code></h2>

{{#if products.length}}
<table style="width:100%;border-collapse:collapse;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,.1)">
  <thead style="background:#1a1a2e;color:#fff">
    <tr>
      <th style="padding:.75rem 1rem;text-align:left">Producto</th>
      <th style="padding:.75rem 1rem;text-align:center">Precio</th>
      <th style="padding:.75rem 1rem;text-align:center">Cantidad</th>
      <th style="padding:.75rem 1rem;text-align:center">Subtotal</th>
      <th style="padding:.75rem 1rem;text-align:center">Acciones</th>
    </tr>
  </thead>
  <tbody>
    {{#each products}}
    <tr style="border-bottom:1px solid #eee" data-pid="{{product._id}}">
      <td style="padding:.75rem 1rem">
        <strong>{{product.title}}</strong>
        <br><span style="font-size:.8rem;color:#888">{{product.category}}</span>
      </td>
      <td style="padding:.75rem 1rem;text-align:center">${{product.price}}</td>
      <td style="padding:.75rem 1rem;text-align:center">{{quantity}}</td>
      <td style="padding:.75rem 1rem;text-align:center;font-weight:600">${{subtotal}}</td>
      <td style="padding:.75rem 1rem;text-align:center">
        <button class="btn btn-danger btn-remove" data-pid="{{product._id}}" style="font-size:.8rem;padding:.3rem .8rem">Eliminar</button>
      </td>
    </tr>
    {{/each}}
  </tbody>
  <tfoot>
    <tr style="background:#f5f5f5;font-weight:700">
      <td colspan="3" style="padding:.75rem 1rem;text-align:right">Total:</td>
      <td style="padding:.75rem 1rem;text-align:center;font-size:1.1rem">${{total}}</td>
      <td style="padding:.75rem 1rem;text-align:center">
        <button id="btn-clear" class="btn btn-danger" style="font-size:.8rem;padding:.3rem .8rem">Vaciar</button>
      </td>
    </tr>
  </tfoot>
</table>
{{else}}
<div class="card" style="text-align:center;padding:2rem;color:#888">
  <p style="font-size:1.5rem">🛒</p>
  <p>El carrito está vacío.</p>
  <a href="/products" class="btn btn-primary" style="margin-top:1rem">Ver productos</a>
</div>
{{/if}}

<script>
  const CID = '{{cartId}}';

  document.querySelectorAll('.btn-remove').forEach(btn => {
    btn.addEventListener('click', async () => {
      const pid = btn.dataset.pid;
      const res = await fetch(`/api/carts/${CID}/products/${pid}`, { method: 'DELETE' });
      if (res.ok) { btn.closest('tr').remove(); showToast('Producto eliminado'); }
    });
  });

  const btnClear = document.getElementById('btn-clear');
  if (btnClear) {
    btnClear.addEventListener('click', async () => {
      const res = await fetch(`/api/carts/${CID}`, { method: 'DELETE' });
      if (res.ok) location.reload();
    });
  }
</script>
