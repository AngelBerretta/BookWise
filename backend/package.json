{
  "name": "backend-ecommerce",
  "version": "1.0.0",
  "description": "API de e-commerce — productos y carritos",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node src/scripts/seedProducts.js",
    "seed:blog": "node src/scripts/seedBlog.js",
    "seed:demo": "node src/scripts/seedDemo.js",
    "seed:all": "npm run seed && npm run seed:blog && npm run seed:demo",
    "cleanup:images": "node src/scripts/cleanupCloudinaryOrphans.js",
    "dev:fs": "nodemon src/app.js --mode fs"
  },
  "dependencies": {
    "@coffeeandfun/google-profanity-words": "^3.0.7",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-handlebars": "^9.0.1",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "minimist": "^1.2.8",
    "mongodb": "^7.2.0",
    "mongoose": "^8.23.1",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
